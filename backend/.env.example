# PRAVAH backend environment — copy to .env (`cp .env.example .env`)

# --- Database: Supabase Postgres ------------------------------------------- #
# Get this from Supabase: Project -> Connect -> ORMs / "Connection string".
# Use the SESSION POOLER string (port 5432) — it's IPv4-friendly and supports
# prepared statements. Replace [YOUR-PASSWORD], [REGION], and [PROJECT-REF].
#
# Session pooler (recommended):
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#
# Direct connection (IPv6 only — use if your network has IPv6):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# The app auto-rewrites postgresql:// -> postgresql+psycopg:// (psycopg v3).

RAW_CSV_PATH=data/raw/Astram_event_data_anonymized_-_Astram_event_data_anonymizedb40ac87.csv
TIMEZONE=Asia/Kolkata
AUTH_DISABLED=true
# Supabase JWT verification (HS256) — only required when AUTH_DISABLED=false.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUD=authenticated
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
